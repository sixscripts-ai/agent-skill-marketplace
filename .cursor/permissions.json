{
  "terminalAllowlist": [
    "pnpm *",
    "npm *",
    "npx *",
    "node *",
    "tsx *",
    "prisma *",
    "git status",
    "git diff*",
    "git log*",
    "git add *",
    "git commit *",
    "git branch*",
    "git checkout *",
    "git switch *",
    "git pull*",
    "git fetch*",
    "curl *localhost*",
    "curl *127.0.0.1*",
    "playwright *"
  ],
  "terminalDenylist": [
    "git push --force*",
    "git reset --hard*",
    "rm -rf /",
    "rm -rf ~",
    "sudo *"
  ],
  "mcpAllowlist": ["*"],
  "autoRun": {
    "allow_instructions": [
      "Run lint",
      "Run typecheck",
      "Run tests",
      "Install dependencies",
      "Build Marketplace Forge"
    ],
    "block_instructions": [
      "Force push",
      "Hard reset",
      "Delete production data",
      "Commit secrets"
    ]
  }
}
